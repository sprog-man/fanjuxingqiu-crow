<scroll-view class="page" scroll-y>
  <!-- Step Progress -->
  <view class="step-progress">
    <view wx:for="{{steps}}" wx:key="index" class="step-dot {{currentStep >= index ? 'active' : ''}}"
      data-step="{{index}}" bindtap="jumpStep">
      <text class="step-num">{{index + 1}}</text>
      <text class="step-name">{{item}}</text>
    </view>
  </view>

  <!-- Step 1: 基础信息 -->
  <view wx:if="{{currentStep === 0}}" class="step-content">
    <view class="form-group">
      <text class="form-label">聚餐名称 *</text>
      <input class="form-input" placeholder="如「重庆火锅之夜」" value="{{form.title}}" data-field="title" bindinput="onFormInput" />
    </view>
    <view class="form-group">
      <text class="form-label">时间 *</text>
      <picker mode="date" value="{{form.date}}" data-field="date" bindchange="onFieldChange">
        <view class="form-picker">{{form.date || '选择日期'}}</view>
      </picker>
      <picker mode="time" value="{{form.time}}" data-field="time" bindchange="onFieldChange">
        <view class="form-picker">{{form.time || '选择时间'}}</view>
      </picker>
    </view>
    <view class="form-group">
      <text class="form-label">地点 *</text>
      <input class="form-input" placeholder="如「渝味晓宇火锅」" value="{{form.locationName}}" data-field="locationName" bindinput="onFormInput" />
      <input class="form-input" placeholder="城市（如重庆）" value="{{form.city}}" data-field="city" bindinput="onFormInput" />
    </view>
    <view class="form-group">
      <text class="form-label">照片（选填，最多9张）</text>
      <view class="photo-grid">
        <view wx:for="{{photoPreviews}}" wx:key="*this" class="photo-preview">
          <image class="photo-img" src="{{item}}" mode="aspectFill" />
          <text class="photo-remove" data-index="{{index}}" bindtap="removePhoto">×</text>
        </view>
        <view wx:if="{{photos.length < 9}}" class="photo-add" bindtap="pickPhotos">
          <text class="photo-add-icon">+</text>
          <text class="photo-add-text">{{photos.length}}/9</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Step 2: 参与人员 -->
  <view wx:if="{{currentStep === 1}}" class="step-content">
    <view class="form-group">
      <text class="form-label">参与人员 *</text>
      <view class="input-row">
        <input class="form-input half" placeholder="输入姓名" value="{{participantInput}}" bindinput="onParticipantInput" />
        <button class="add-btn" bindtap="addParticipant">添加</button>
      </view>
      <view class="buddy-shortcut" bindtap="showBuddyPicker">
        <text>👥 从饭搭子中选择</text>
      </view>
      <view class="tag-list">
        <view wx:for="{{form.participants}}" wx:key="index" class="tag-item">
          <text>{{item}}</text>
          <text class="tag-remove" data-index="{{index}}" bindtap="removeParticipant">×</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Step 3: 消费信息（二选一） -->
  <view wx:if="{{currentStep === 2}}" class="step-content">
    <view class="pay-toggle">
      <view class="pay-option {{payMode === 'aa' ? 'active' : ''}}" data-mode="aa" bindtap="setPayMode">
        <text class="pay-option-icon">💰</text>
        <text class="pay-option-name">AA支付</text>
        <text class="pay-option-desc">按人数均摊</text>
      </view>
      <view class="pay-option {{payMode === 'single' ? 'active' : ''}}" data-mode="single" bindtap="setPayMode">
        <text class="pay-option-icon">👤</text>
        <text class="pay-option-name">单人买单</text>
        <text class="pay-option-desc">指定一个人付全款</text>
      </view>
    </view>

    <view class="form-group">
      <text class="form-label">总消费（元）*</text>
      <input class="form-input" placeholder="如 268" type="digit" value="{{form.totalCost}}" data-field="totalCost" bindinput="onFormInput" />
    </view>

    <view wx:if="{{payMode === 'aa'}}" class="aa-preview">
      <text class="aa-preview-text">{{form.participants.length}}人 · 人均 {{aaPerPerson}} 元</text>
    </view>

    <view wx:if="{{payMode === 'single'}}" class="form-group">
      <text class="form-label">买单人</text>
      <picker mode="selector" range="{{form.participants}}" value="{{payerIndex}}" bindchange="onPayerChange">
        <view class="form-picker">{{payerIndex >= 0 ? form.participants[payerIndex] : '选择谁买的单'}}</view>
      </picker>
    </view>
  </view>

  <!-- Step 4: 心情标签 -->
  <view wx:if="{{currentStep === 3}}" class="step-content">
    <view class="form-group">
      <text class="form-label">满意度</text>
      <view class="star-row">
        <text wx:for="{{[1,2,3,4,5]}}" wx:key="*this"
          class="star {{form.moodScore >= item ? 'active' : ''}}"
          data-score="{{item}}" bindtap="setScore">★</text>
      </view>
    </view>
    <view class="form-group">
      <text class="form-label">心情标签（点击选择/取消）</text>
      <view class="tag-list mood-tags">
        <view wx:for="{{moodTagOptions}}" wx:key="*this"
          class="tag-item {{moodTagSelected[index] ? 'selected' : ''}}"
          data-tag="{{item}}" data-index="{{index}}" bindtap="toggleMoodTag">{{item}}</view>
      </view>
      <view class="custom-tag-row">
        <input class="form-input half" placeholder="自定义标签" value="{{customTagInput}}" bindinput="onCustomTagInput" />
        <button class="add-btn" bindtap="addCustomTag">添加</button>
      </view>
    </view>
    <view class="form-group">
      <text class="form-label">备注</text>
      <textarea class="form-textarea" placeholder="记录想说的话..." value="{{form.note}}" data-field="note" bindinput="onFormInput" />
    </view>
  </view>

  <!-- Navigation -->
  <view class="step-nav">
    <button wx:if="{{currentStep > 0}}" class="nav-btn secondary" bindtap="prevStep">上一步</button>
    <button wx:if="{{currentStep < steps.length - 1}}" class="nav-btn primary" bindtap="nextStep">
      下一步 {{currentStep + 2}}/{{steps.length}}
    </button>
    <button wx:if="{{currentStep === steps.length - 1}}" class="nav-btn primary" bindtap="submitForm">
      ✅ 完成记录
    </button>
  </view>

  <!-- 饭搭子弹窗 -->
  <view wx:if="{{showBuddyModal}}" class="modal-overlay" bindtap="closeBuddyPicker">
    <view class="buddy-picker" catchtap>
      <text class="buddy-picker-title">选择饭搭子</text>
      <input class="buddy-search" placeholder="搜索..." value="{{buddySearch}}" bindinput="onBuddySearch" />
      <scroll-view class="buddy-list" scroll-y>
        <view wx:for="{{filteredBuddies}}" wx:key="id" class="buddy-pick-item" data-name="{{item.name}}" bindtap="pickBuddy">
          <view wx:if="{{!item._avatarUrl}}" class="bp-avatar" style="background:{{item.color}}">{{item.name.slice(0,1)}}</view>
          <image wx:else class="bp-avatar-img" src="{{item._avatarUrl}}" mode="aspectFill"></image>
          <view class="bp-info-col">
            <text class="bp-name">{{item.name}}</text>
            <text class="bp-status">已互为饭搭子</text>
            <text class="bp-buddy-id" wx:if="{{item.buddy_id}}">{{'ID: ' + item.buddy_id}}</text>
          </view>
          <text wx:if="{{item.phone}}" class="bp-phone">{{item.phone}}</text>
          <text wx:if="{{!item.added}}" class="bp-add">+</text>
          <text wx:if="{{item.added}}" class="bp-added">已添加</text>
        </view>
        <view wx:if="{{filteredBuddies.length === 0}}" class="bp-empty">没有匹配的饭搭子</view>
      </scroll-view>
      <button class="buddy-close" bindtap="closeBuddyPicker">关闭</button>
    </view>
  </view>
</scroll-view>
