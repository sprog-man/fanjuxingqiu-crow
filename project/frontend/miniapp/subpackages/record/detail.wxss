.page { min-height: 100vh; background: #f8f6f3; padding-bottom: 30px; }

.hero {
  background: linear-gradient(135deg, #D85A30, #e07a50);
  padding: 32px 24px;
  color: #fff;
}

.hero-title {
  display: block;
  font-size: 22px;
  font-weight: 700;
  margin-bottom: 8px;
}

.hero-meta {
  display: flex;
  gap: 16px;
}

.hero-time, .hero-location {
  font-size: 13px;
  opacity: 0.9;
}

.info-cards {
  display: flex;
  gap: 8px;
  margin: -16px 16px 12px;
  position: relative;
  z-index: 2;
}

.info-item {
  flex: 1;
  background: #fff;
  border-radius: 12px;
  padding: 14px;
  text-align: center;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}

.info-label {
  display: block;
  font-size: 11px;
  color: #5F5E5A;
  margin-bottom: 4px;
}

.info-value {
  display: block;
  font-size: 18px;
  font-weight: 700;
  color: #2C2C2A;
}

.info-value.accent {
  color: #D85A30;
}

.section-card {
  background: #fff;
  border-radius: 14px;
  padding: 16px;
  margin: 0 16px 10px;
}

.section-title {
  display: block;
  font-size: 14px;
  font-weight: 600;
  color: #2C2C2A;
  margin-bottom: 12px;
}

.participant-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.participant-badge {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 8px 14px;
  background: #f5f5f5;
  border-radius: 20px;
  font-size: 13px;
  color: #2C2C2A;
}

.participant-badge.payer {
  background: #FAECE7;
  border: 1px solid #D85A30;
}

.payer-tag {
  font-size: 10px;
  background: #D85A30;
  color: #fff;
  padding: 2px 8px;
  border-radius: 8px;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.mood-badge {
  padding: 4px 12px;
  background: #FAECE7;
  border-radius: 12px;
  font-size: 12px;
  color: #D85A30;
}

.note-text {
  font-size: 14px;
  color: #5F5E5A;
  line-height: 1.6;
}

.loading {
  text-align: center;
  padding: 80px 0;
  color: #5F5E5A;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}

.loading-spinner {
  width: 32px; height: 32px;
  border: 3px solid #f0e8e0;
  border-top-color: #D85A30;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.error-state {
  text-align: center;
  padding: 80px 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}

.error-icon { font-size: 48px; display: block; }
.error-text { font-size: 15px; color: #5F5E5A; display: block; }

.error-retry {
  margin-top: 12px;
  padding: 10px 28px;
  background: #D85A30;
  color: #fff;
  border-radius: 10px;
  font-size: 14px;
  font-weight: 500;
}
