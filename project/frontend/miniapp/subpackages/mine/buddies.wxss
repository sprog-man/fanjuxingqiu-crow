.page { min-height: 100vh; background: #f8f6f3; }
.page-inner { padding: 16px; }
.header-note { font-size: 13px; color: #5F5E5A; text-align: center; margin-bottom: 16px; }

.add-buddy-btn { height: 44px; line-height: 44px; background: #D85A30; color: #fff; font-size: 15px; border-radius: 12px; margin-bottom: 12px; }

.buddy-card { display: flex; align-items: center; gap: 12px; background: #fff; border-radius: 14px; padding: 12px 14px; margin-bottom: 8px; }
.buddy-avatar-wrap { width: 42px; height: 42px; border-radius: 50%; overflow: hidden; flex-shrink: 0; }
.buddy-avatar-img { width: 100%; height: 100%; }
.buddy-avatar-letter { width: 100%; height: 100%; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 18px; font-weight: 700; color: #fff; }
.buddy-info { flex: 1; min-width: 0; }
.buddy-name { display: block; font-size: 15px; font-weight: 500; color: #2C2C2A; }
.buddy-phone { display: block; font-size: 12px; color: #5F5E5A; margin-top: 2px; }
.buddy-actions { display: flex; gap: 8px; flex-shrink: 0; }
.buddy-edit, .buddy-del { width: 28px; height: 28px; line-height: 28px; text-align: center; border-radius: 50%; font-size: 16px; }
.buddy-edit { background: #FAECE7; color: #D85A30; }
.buddy-del { background: #fee; color: #e55; }

.empty-state { text-align: center; padding: 60px 0; }
.empty-icon { font-size: 48px; display: block; margin-bottom: 8px; }
.empty-text { font-size: 16px; color: #2C2C2A; display: block; }
.empty-hint { font-size: 13px; color: #999; margin-top: 4px; display: block; }

/* Modal */
.modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.4); display: flex; align-items: center; justify-content: center; z-index: 100; }
.modal-card { background: #fff; border-radius: 20px; padding: 28px 24px; width: 300px; }
.modal-title { display: block; font-size: 17px; font-weight: 600; color: #2C2C2A; margin-bottom: 16px; text-align: center; }

/* Avatar picker */
.avatar-picker { display: flex; flex-direction: column; align-items: center; margin-bottom: 16px; }
.avatar-preview { width: 72px; height: 72px; border-radius: 50%; overflow: hidden; }
.avatar-preview-empty { background: #f0eeeb; display: flex; align-items: center; justify-content: center; border: 2px dashed #ccc; }
.avatar-preview-text { font-size: 28px; }
.avatar-picker-hint { display: block; font-size: 12px; color: #999; margin-top: 6px; }

.modal-input { height: 44px; line-height: 44px; padding: 0 14px; background: #f5f5f5; border-radius: 10px; font-size: 14px; color: #2C2C2A; width: 100%; margin-bottom: 10px; }
.modal-actions { display: flex; gap: 10px; margin-top: 8px; }
.modal-cancel { flex: 1; height: 40px; line-height: 40px; background: #f5f5f5; color: #2C2C2A; font-size: 14px; border-radius: 10px; }
.modal-confirm { flex: 1; height: 40px; line-height: 40px; background: #D85A30; color: #fff; font-size: 14px; border-radius: 10px; }
