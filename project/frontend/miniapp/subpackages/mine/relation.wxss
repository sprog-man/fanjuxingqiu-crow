.page { min-height: 100vh; background: #f8f6f3; padding-bottom: 30px; }

.header {
  padding: 32px 24px 16px;
  text-align: center;
}

.header-title {
  display: block;
  font-size: 22px;
  font-weight: 600;
  color: #2C2C2A;
  margin-bottom: 4px;
}

.header-sub {
  display: block;
  font-size: 14px;
  color: #5F5E5A;
}

.graph-container {
  display: flex;
  justify-content: center;
  margin: 8px 12px;
  background: linear-gradient(180deg, #fff 0%, #f8f6f3 100%);
  border-radius: 20px;
  box-shadow: 0 4px 24px rgba(0,0,0,0.06);
  padding: 8px;
}

.graph-canvas {
  border-radius: 16px;
  background: #fff;
}

.friend-list {
  padding: 0 16px;
}

.friend-card {
  display: flex;
  align-items: center;
  gap: 12px;
  background: #fff;
  border-radius: 14px;
  padding: 14px;
  margin-bottom: 8px;
}

.friend-avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.friend-avatar-text {
  font-size: 20px;
  font-weight: 700;
  color: #fff;
}

.friend-info {
  flex: 1;
}

.friend-top {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 2px;
}

.friend-name {
  font-size: 15px;
  font-weight: 600;
  color: #2C2C2A;
}

.friend-title {
  font-size: 11px;
  color: #D85A30;
  background: #FAECE7;
  padding: 2px 8px;
  border-radius: 8px;
}

.friend-level {
  font-size: 11px;
  color: #5F5E5A;
  display: block;
  margin-bottom: 2px;
}

.friend-desc {
  font-size: 11px;
  color: #5F5E5A;
  display: block;
  margin-bottom: 4px;
}

.friend-stats {
  display: flex;
  gap: 12px;
  font-size: 11px;
  color: #5F5E5A;
}

.friend-arrow {
  font-size: 20px;
  color: #ccc;
}

/* Modal */
.modal-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal-card {
  background: #fff;
  border-radius: 24px;
  padding: 32px 24px 24px;
  width: 300px;
  text-align: center;
  position: relative;
  overflow: hidden;
  animation: modalIn 0.3s ease-out;
}

@keyframes modalIn {
  from { opacity: 0; transform: scale(0.9) translateY(20px); }
  to { opacity: 1; transform: scale(1) translateY(0); }
}

.modal-glow {
  position: absolute;
  top: -40px;
  left: 50%;
  transform: translateX(-50%);
  width: 120px;
  height: 120px;
  border-radius: 50%;
  opacity: 0.12;
  filter: blur(24px);
}

.modal-avatar {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 12px;
  font-size: 26px;
  font-weight: 700;
  color: #fff;
  position: relative;
  box-shadow: 0 4px 16px rgba(0,0,0,0.12);
}

.modal-name {
  display: block;
  font-size: 20px;
  font-weight: 600;
  color: #2C2C2A;
  margin-bottom: 8px;
}

.modal-title-badge {
  display: inline-flex;
  gap: 6px;
  background: #FAECE7;
  padding: 5px 16px;
  border-radius: 20px;
  font-size: 13px;
  color: #D85A30;
  margin-bottom: 8px;
}

.modal-desc {
  display: block;
  font-size: 13px;
  color: #5F5E5A;
  margin-bottom: 18px;
  line-height: 1.5;
}

.modal-stats {
  display: flex;
  gap: 8px;
  margin-bottom: 14px;
}

.modal-stat {
  flex: 1;
  background: #f8f6f3;
  padding: 12px 8px;
  border-radius: 12px;
  transition: transform 0.2s;
}

.modal-stat:active {
  transform: scale(0.95);
}

.ms-num {
  display: block;
  font-size: 20px;
  font-weight: 700;
  color: #2C2C2A;
}

.ms-label {
  display: block;
  font-size: 10px;
  color: #5F5E5A;
  margin-top: 2px;
}

.modal-cities {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 6px;
  margin-bottom: 18px;
}

.city-badge {
  padding: 4px 12px;
  background: #FAECE7;
  border-radius: 14px;
  font-size: 11px;
  color: #D85A30;
}

.modal-close {
  height: 42px;
  line-height: 42px;
  background: #f5f5f5;
  color: #2C2C2A;
  font-size: 14px;
  border-radius: 12px;
  width: 100%;
}
