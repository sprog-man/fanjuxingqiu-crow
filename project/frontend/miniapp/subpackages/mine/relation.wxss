.page { min-height: 100vh; background: #F1EFE8; padding: 0 0 30px; }

/* ── Tab Row ── */
.tab-row {
  display: flex;
  gap: 8px;
  padding: 16px 16px 4px;
  position: sticky;
  top: 0;
  z-index: 10;
  background: #F1EFE8;
}
.tab {
  flex: 1;
  padding: 10px 0;
  text-align: center;
  font-size: 14px;
  font-weight: 500;
  border-radius: 10px;
  border: 0.5px solid #ddd;
  color: #888;
  background: #fff;
  cursor: pointer;
  transition: all 0.2s;
}
.tab.on {
  background: #D85A30;
  color: #fff;
  border-color: #D85A30;
}
.tab:active { opacity: 0.8; }

/* ── My Card ── */
.my-card {
  background: #fff;
  border-radius: 14px;
  padding: 18px 16px;
  margin: 12px 16px 10px;
  display: flex;
  align-items: center;
  gap: 14px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.04);
}
.my-avatar {
  width: 54px;
  height: 54px;
  border-radius: 50%;
  background: #FAECE7;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 2px solid #D85A30;
}
.my-avatar-text { font-size: 24px; }
.my-info { flex: 1; }
.my-name { display: block; font-size: 17px; font-weight: 600; color: #2C2C2A; }
.my-sub { display: block; font-size: 12px; color: #888; margin-top: 2px; }
.title-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  margin-top: 6px;
  padding: 4px 12px;
  border-radius: 20px;
  background: #FAECE7;
  font-size: 12px;
  font-weight: 500;
  color: #993C1D;
}
.title-badge-icon { font-size: 13px; }
.title-badge-text { font-size: 12px; }

/* ── Stats Row ── */
.stats-row {
  display: flex;
  gap: 8px;
  padding: 0 16px;
  margin-bottom: 12px;
}
.stat-card {
  flex: 1;
  background: #fff;
  border-radius: 10px;
  padding: 12px 8px;
  text-align: center;
  box-shadow: 0 2px 8px rgba(0,0,0,0.03);
}
.stat-num { display: block; font-size: 22px; font-weight: 600; color: #2C2C2A; }
.stat-label { display: block; font-size: 11px; color: #888; margin-top: 2px; }

/* ── Friend Grid ── */
.friend-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  padding: 0 16px;
}
.friend-card {
  background: #fff;
  border-radius: 14px;
  padding: 14px;
  position: relative;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0,0,0,0.03);
  transition: all 0.2s;
}
.friend-card:active { border-color: #D85A30; transform: scale(0.97); }
.card-top { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
.card-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 15px;
  font-weight: 600;
  flex-shrink: 0;
}
.card-info { flex: 1; min-width: 0; }
.card-name { display: block; font-size: 14px; font-weight: 500; color: #2C2C2A; }
.card-sub { display: block; font-size: 11px; color: #888; margin-top: 1px; }

.tier-bar {
  height: 3px;
  border-radius: 2px;
  background: #eee;
  margin-bottom: 8px;
  overflow: hidden;
}
.tier-fill {
  height: 100%;
  border-radius: 2px;
  transition: width 0.4s ease;
}

.badge-sm {
  display: inline-block;
  font-size: 10px;
  padding: 3px 10px;
  border-radius: 20px;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100%;
}

.lock-overlay {
  position: absolute;
  inset: 0;
  background: rgba(241,239,232,0.92);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4px;
  z-index: 2;
  border-radius: 14px;
}
.lock-icon { font-size: 22px; }
.lock-text { font-size: 11px; color: #888; }
.lock-overlay-bottom {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 4px;
  background: transparent;
}

/* ── Detail Page ── */
.detail-page {
  padding: 0 16px;
}
.back-btn {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 14px;
  color: #D85A30;
  padding: 12px 0 8px;
  font-weight: 500;
}
.back-btn:active { opacity: 0.7; }
.back-arrow { font-size: 22px; line-height: 1; }

.hero-card {
  background: #fff;
  border-radius: 14px;
  padding: 20px 16px;
  margin-bottom: 10px;
  text-align: center;
  box-shadow: 0 2px 12px rgba(0,0,0,0.04);
}
.hero-avatar {
  width: 68px;
  height: 68px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  font-weight: 600;
  margin: 0 auto 10px;
  border: 2.5px solid #D85A30;
  box-shadow: 0 4px 16px rgba(0,0,0,0.08);
}
.hero-name { display: block; font-size: 18px; font-weight: 600; color: #2C2C2A; }
.hero-sub { display: block; font-size: 13px; color: #888; margin-top: 3px; }
.hero-stars { letter-spacing: 2px; font-size: 15px; margin-top: 5px; color: #D85A30; }
.hero-title-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  margin-top: 10px;
  padding: 6px 16px;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 500;
}
.hero-desc {
  display: block;
  font-size: 13px;
  color: #888;
  margin-top: 10px;
  line-height: 1.6;
  padding: 0 8px;
}

.detail-stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  margin-bottom: 10px;
}
.dsc {
  background: #fff;
  border-radius: 10px;
  padding: 14px 8px;
  text-align: center;
  box-shadow: 0 2px 8px rgba(0,0,0,0.03);
}
.dsc-num { display: block; font-size: 20px; font-weight: 600; color: #2C2C2A; }
.dsc-label { display: block; font-size: 11px; color: #888; margin-top: 3px; }

.info-card {
  background: #fff;
  border-radius: 14px;
  padding: 16px;
  margin-bottom: 10px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.03);
}
.info-card-header { margin-bottom: 10px; }
.info-card-title { font-size: 14px; font-weight: 500; color: #2C2C2A; }

.timeline-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 0;
  border-bottom: 0.5px solid #f0f0f0;
}
.timeline-item:last-child { border-bottom: none; }
.tl-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.tl-emoji { font-size: 14px; }
.tl-text { flex: 1; font-size: 13px; color: #2C2C2A; }
.tl-date { font-size: 12px; color: #888; flex-shrink: 0; }

.empty-hint { text-align: center; padding: 16px 0; font-size: 13px; color: #bbb; }

.tags-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}
.food-tag {
  font-size: 11px;
  padding: 4px 12px;
  border-radius: 20px;
  font-weight: 400;
}
.city-tag {
  font-size: 11px;
  padding: 4px 12px;
  border-radius: 20px;
  background: #FAEEDA;
  color: #854F0B;
  font-weight: 400;
}

/* ── Atlas Page ── */
.atlas-page {
  padding: 8px 16px 20px;
}
.atlas-section { margin-bottom: 20px; }
.atlas-section-title {
  display: block;
  font-size: 12px;
  font-weight: 600;
  color: #888;
  margin-bottom: 10px;
  letter-spacing: 1px;
  text-transform: uppercase;
}
.atlas-card {
  background: #fff;
  border-radius: 14px;
  padding: 14px;
  margin-bottom: 8px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.03);
  transition: all 0.2s;
}
.atlas-card:active { transform: scale(0.98); }
.atlas-locked { opacity: 0.7; }
.atlas-row { display: flex; gap: 12px; align-items: flex-start; }
.atlas-icon {
  width: 44px;
  height: 44px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.atlas-icon-text { font-size: 20px; }
.atlas-info { flex: 1; min-width: 0; }
.atlas-name { display: block; font-size: 14px; font-weight: 600; color: #2C2C2A; }
.atlas-desc {
  display: block;
  font-size: 11px;
  color: #888;
  margin-top: 4px;
  line-height: 1.5;
}
.atlas-desc-locked { color: #bbb; }
.atlas-badge {
  display: inline-block;
  font-size: 10px;
  font-weight: 500;
  padding: 3px 10px;
  border-radius: 20px;
  margin-top: 6px;
}
.atlas-lock-hint {
  display: flex;
  align-items: center;
  gap: 4px;
  margin-top: 6px;
}
.atlas-lock-icon { font-size: 12px; }
.atlas-lock-text { font-size: 11px; color: #888; }

.demo-btn {
  width: 100%;
  height: 44px;
  line-height: 44px;
  border-radius: 12px;
  border: 0.5px solid #ddd;
  background: transparent;
  font-size: 13px;
  color: #D85A30;
  margin-top: 4px;
  text-align: center;
}
.demo-btn:active {
  background: #f5f5f5;
}

/* ── Unlock Modal ── */
.modal-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
  animation: fadeIn 0.2s ease;
}
.modal-card {
  background: #fff;
  border-radius: 24px;
  padding: 32px 24px 24px;
  width: 300px;
  text-align: center;
  animation: slideUp 0.3s ease-out;
}
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes slideUp {
  from { transform: translateY(60px); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}
.modal-kicker {
  font-size: 12px;
  color: #D85A30;
  font-weight: 600;
  margin-bottom: 12px;
  letter-spacing: 2px;
}
.modal-icon-wrap {
  width: 68px;
  height: 68px;
  border-radius: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 14px;
  animation: iconPop 0.4s ease-out 0.2s both;
}
@keyframes iconPop {
  from { transform: scale(0.5); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}
.modal-icon-text { font-size: 30px; }
.modal-title { font-size: 22px; font-weight: 600; color: #2C2C2A; margin-bottom: 4px; }
.modal-stars { font-size: 16px; color: #D85A30; margin-bottom: 10px; letter-spacing: 3px; }
.modal-sub { font-size: 12px; color: #888; margin-bottom: 8px; }
.modal-desc { font-size: 13px; color: #444; line-height: 1.7; margin-bottom: 22px; }
.modal-btn {
  width: 100%;
  height: 46px;
  line-height: 46px;
  border-radius: 12px;
  border: none;
  background: linear-gradient(135deg, #D85A30, #c04a20);
  color: #fff;
  font-size: 15px;
  font-weight: 500;
}
.modal-btn:active { opacity: 0.8; }
