<scroll-view class="page" scroll-y>
  <view class="page-inner">
    <view class="header-note">添加数据库中已存在的用户作为饭搭子，自动获取信息</view>

    <button class="add-buddy-btn" bindtap="showAdd">+ 添加饭搭子</button>

    <!-- 饭搭子列表 -->
    <view wx:for="{{buddies}}" wx:key="id" class="buddy-card">
      <view class="buddy-avatar-wrap">
        <image wx:if="{{item.avatar}}" class="buddy-avatar-img" src="{{item.avatar}}" mode="aspectFill"></image>
        <view wx:else class="buddy-avatar-letter" style="background:{{item.color || '#D85A30'}}">
          <text>{{item.initial}}</text>
        </view>
      </view>
      <view class="buddy-info">
        <text class="buddy-name">{{item.remark || item.name}}</text>
        <view class="buddy-meta">
          <text class="buddy-original-name" wx:if="{{item.remark && item.remark !== item.name}}">{{item.name}}</text>
          <text wx:if="{{item.phone}}" class="buddy-phone">{{item.phone}}</text>
        </view>
      </view>
      <view class="buddy-actions">
        <text class="buddy-remark-btn" data-id="{{item._id || item.id}}" bindtap="setRemark">✎</text>
        <text class="buddy-del" data-id="{{item._id || item.id}}" bindtap="deleteBuddy">×</text>
      </view>
    </view>

    <view wx:if="{{buddies.length === 0}}" class="empty-state">
      <text class="empty-icon">👥</text>
      <text class="empty-text">还没有饭搭子</text>
      <text class="empty-hint">添加你的聚餐伙伴吧</text>
    </view>
  </view>

  <!-- Add/Edit Modal -->
  <view wx:if="{{showModal}}" class="modal-overlay" bindtap="closeModal">
    <view class="modal-card" catchtap="preventClose">
      <text class="modal-title">{{editingId ? '设置备注' : (selectMode === 'search' ? '添加饭搭子' : '确认添加')}}</text>

      <!-- Step 1: Search -->
      <block wx:if="{{selectMode === 'search'}}">
        <input class="search-input" placeholder="搜索用户昵称..." value="{{searchQuery}}" bindinput="onSearchInput" maxlength="20" focus="true" />
        <view class="search-hint" wx:if="{{!searchQuery}}">请输入用户昵称搜索</view>

        <!-- 搜索结果 -->
        <scroll-view class="search-results" scroll-y wx:if="{{searchResults.length > 0}}">
          <view wx:for="{{searchResults}}" wx:key="_id" class="search-item" data-index="{{index}}" bindtap="selectUser">
            <image wx:if="{{item.avatar}}" class="search-avatar" src="{{item.avatar}}" mode="aspectFill"></image>
            <view wx:else class="search-avatar search-avatar-letter" style="background:{{item.name ? '#D85A30' : '#ccc'}}">
              <text>{{item._initial || '?'}}</text>
            </view>
            <view class="search-info">
              <text class="search-name">{{item.name}}</text>
              <text wx:if="{{item.phone}}" class="search-phone">{{item.phone}}</text>
            </view>
            <text class="search-select">选择</text>
          </view>
        </scroll-view>

        <view wx:elif="{{searchQuery && searchResults.length === 0}}" class="search-empty">
          <text>未找到匹配的用户</text>
        </view>
      </block>

      <!-- Step 2: Confirm + Remark -->
      <block wx:if="{{selectMode === 'confirm' && selectedUser}}">
        <view class="selected-user">
          <image wx:if="{{selectedUser.avatar}}" class="selected-avatar" src="{{selectedUser.avatar}}" mode="aspectFill"></image>
          <view wx:else class="selected-avatar selected-avatar-letter" style="background:#D85A30">
            <text>{{selectedUser._initial}}</text>
          </view>
          <view class="selected-info">
            <text class="selected-name">{{selectedUser.name}}</text>
            <text wx:if="{{selectedUser.phone}}" class="selected-phone">{{selectedUser.phone}}</text>
          </view>
        </view>

        <view class="remark-section">
          <text class="remark-label">备注（可选）</text>
          <input class="remark-input" placeholder="设置一个备注名" value="{{editRemark}}" bindinput="onRemarkInput" maxlength="20" />
        </view>

        <view class="modal-actions">
          <button class="modal-cancel" bindtap="closeModal">取消</button>
          <button class="modal-confirm" bindtap="{{editingId ? 'saveRemark' : 'saveBuddy'}}">
            {{editingId ? '保存备注' : '确认添加'}}
          </button>
        </view>
      </block>
    </view>
  </view>
</scroll-view>
