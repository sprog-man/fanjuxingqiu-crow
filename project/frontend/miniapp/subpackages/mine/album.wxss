.page { min-height: 100vh; background: #f8f6f3; padding-bottom: 30px; }

.header {
  padding: 32px 24px 16px;
  text-align: center;
}

.header-title {
  display: block;
  font-size: 22px;
  font-weight: 600;
  color: #2C2C2A;
  margin-bottom: 4px;
}

.header-sub {
  display: block;
  font-size: 14px;
  color: #5F5E5A;
}

/* Album Grid */
.album-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  padding: 0 16px;
}

.album-card {
  background: #fff;
  border-radius: 14px;
  overflow: hidden;
}

.album-cover {
  height: 100px;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.album-cover-text {
  font-size: 24px;
  font-weight: 700;
  color: #fff;
  opacity: 0.9;
}

.album-cost {
  position: absolute;
  top: 8px;
  right: 8px;
  background: rgba(0,0,0,0.3);
  color: #fff;
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 8px;
}

.album-body {
  padding: 10px 12px 12px;
}

.album-title {
  display: block;
  font-size: 14px;
  font-weight: 600;
  color: #2C2C2A;
  margin-bottom: 2px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.album-date {
  display: block;
  font-size: 11px;
  color: #5F5E5A;
  margin-bottom: 8px;
}

.album-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.album-avatars {
  display: flex;
}

.album-avatar {
  width: 20px;
  height: 20px;
  line-height: 20px;
  text-align: center;
  background: #FAECE7;
  border-radius: 50%;
  font-size: 9px;
  color: #D85A30;
  border: 1.5px solid #fff;
  margin-left: -5px;
}

.album-avatar:first-child { margin-left: 0; }

.album-avatar-more {
  width: 20px;
  height: 20px;
  line-height: 20px;
  text-align: center;
  background: #f0f0f0;
  border-radius: 50%;
  font-size: 8px;
  color: #5F5E5A;
  margin-left: -5px;
  border: 1.5px solid #fff;
}

.album-tags {
  display: flex;
  gap: 3px;
}

.album-tag {
  font-size: 9px;
  background: #FAECE7;
  color: #D85A30;
  padding: 2px 6px;
  border-radius: 6px;
}

/* Modal */
.modal-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 100;
}

.modal-scroll {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  max-height: 85vh;
  background: #f8f6f3;
  border-radius: 20px 20px 0 0;
  padding-bottom: 30px;
}

.modal-hero {
  padding: 32px 24px;
  text-align: center;
  border-radius: 20px 20px 0 0;
}

.modal-hero-title {
  font-size: 22px;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 6px;
}

.modal-hero-meta {
  font-size: 13px;
  color: rgba(255,255,255,0.85);
}

.modal-section {
  padding: 16px 20px;
}

.info-row, .modal-info-row {
  display: flex;
  gap: 8px;
}

.modal-info-item {
  flex: 1;
  background: #fff;
  border-radius: 12px;
  padding: 12px;
  text-align: center;
}

.mi-label {
  display: block;
  font-size: 11px;
  color: #5F5E5A;
  margin-bottom: 4px;
}

.mi-value {
  display: block;
  font-size: 16px;
  font-weight: 700;
  color: #2C2C2A;
}

.mi-value.accent { color: #D85A30; }

.modal-section-title {
  display: block;
  font-size: 14px;
  font-weight: 600;
  color: #2C2C2A;
  margin-bottom: 10px;
}

.memory-card {
  background: #fff;
  border-radius: 14px;
  padding: 16px;
  margin-bottom: 10px;
}

.memory-text {
  font-size: 14px;
  color: #5F5E5A;
  line-height: 1.7;
}

.memory-actions {
  display: flex;
  gap: 8px;
}

.memory-btn {
  height: 36px;
  line-height: 36px;
  background: #f5f5f5;
  color: #2C2C2A;
  font-size: 13px;
  border-radius: 10px;
  padding: 0 16px;
}

.modal-participants {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.mp-badge {
  padding: 6px 14px;
  background: #fff;
  border-radius: 16px;
  font-size: 13px;
  color: #2C2C2A;
}

.modal-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.mt-badge {
  padding: 4px 12px;
  background: #FAECE7;
  border-radius: 12px;
  font-size: 12px;
  color: #D85A30;
}

.modal-note {
  font-size: 14px;
  color: #5F5E5A;
  line-height: 1.6;
}

.poster-btn {
  height: 44px;
  line-height: 44px;
  background: #D85A30;
  color: #fff;
  font-size: 14px;
  border-radius: 12px;
  width: 100%;
}

.modal-close-area {
  padding: 0 20px;
  margin-top: 10px;
}

.modal-close-btn {
  height: 40px;
  line-height: 40px;
  background: #fff;
  color: #2C2C2A;
  font-size: 14px;
  border-radius: 12px;
  width: 100%;
}

/* Empty */
.empty-state {
  text-align: center;
  padding: 80px 0;
}

.empty-icon {
  font-size: 48px;
  display: block;
  margin-bottom: 12px;
}

.empty-text {
  font-size: 16px;
  color: #2C2C2A;
  display: block;
  margin-bottom: 4px;
}

.empty-hint {
  font-size: 13px;
  color: #ccc;
}

/* Photo Scroll */
.photo-scroll { display: flex; gap: 8px; white-space: nowrap; overflow-x: auto; padding-bottom: 4px; }
.photo-thumb { width: 120px; height: 120px; border-radius: 10px; margin-right: 8px; display: inline-block; }
