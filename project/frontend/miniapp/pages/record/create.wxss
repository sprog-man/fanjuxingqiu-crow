.page { min-height: 100vh; background: #f8f6f3; padding-bottom: 40px; }

/* Step Progress */
.step-progress { display: flex; padding: 20px 24px 16px; }
.step-dot { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px; position: relative; }
.step-dot::after { content: ''; position: absolute; top: 12px; left: 50%; width: 100%; height: 2px; background: #DDDDDD; z-index: 0; }
.step-dot:last-child::after { display: none; }
.step-dot.active::after { background: #D85A30; }
.step-num { width: 24px; height: 24px; line-height: 24px; text-align: center; border-radius: 50%; background: #DDDDDD; color: #fff; font-size: 12px; font-weight: 600; z-index: 1; }
.step-dot.active .step-num { background: #D85A30; }
.step-name { font-size: 10px; color: #5F5E5A; }

/* Form */
.step-content { padding: 0 24px; }
.form-group { margin-bottom: 16px; }
.form-label { display: block; font-size: 14px; font-weight: 500; color: #2C2C2A; margin-bottom: 8px; }
.form-input { height: 44px; line-height: 44px; padding: 0 14px; background: #fff; border-radius: 10px; font-size: 14px; color: #2C2C2A; width: 100%; margin-bottom: 8px; }
.form-input.half { width: 60%; display: inline-block; margin-bottom: 0; }
.form-picker { height: 44px; line-height: 44px; padding: 0 14px; background: #fff; border-radius: 10px; font-size: 14px; color: #2C2C2A; margin-bottom: 8px; }
.form-textarea { width: 100%; height: 100px; padding: 12px 14px; background: #fff; border-radius: 10px; font-size: 14px; color: #2C2C2A; }

.input-row { display: flex; gap: 8px; margin-bottom: 10px; }
.add-btn { height: 44px; line-height: 44px; padding: 0 20px; background: #D85A30; color: #fff; font-size: 14px; border-radius: 10px; }

/* 饭搭子快捷入口 */
.buddy-shortcut { display: inline-flex; align-items: center; gap: 4px; padding: 6px 14px; background: #FAECE7; border-radius: 16px; font-size: 13px; color: #D85A30; margin-bottom: 10px; }

/* Tag List */
.tag-list { display: flex; flex-wrap: wrap; gap: 8px; }
.tag-item { padding: 6px 14px; background: #fff; border: 1px solid #DDDDDD; border-radius: 16px; font-size: 13px; color: #5F5E5A; display: flex; align-items: center; gap: 4px; }
.tag-item.selected { background: #FAECE7; border-color: #D85A30; color: #D85A30; }
.tag-remove { width: 18px; height: 18px; line-height: 18px; text-align: center; background: #eee; border-radius: 50%; font-size: 12px; }

/* 心情标签特殊样式 */
.mood-tags .tag-item { padding: 8px 18px; font-size: 14px; }
.mood-tags .tag-item.selected { background: #D85A30; border-color: #D85A30; color: #fff; font-weight: 600; }
.custom-tag-row { display: flex; gap: 8px; margin-top: 10px; align-items: center; }

/* 消费方式二选一 */
.pay-toggle { display: flex; gap: 10px; margin-bottom: 16px; }
.pay-option { flex: 1; background: #fff; border-radius: 14px; padding: 16px; text-align: center; border: 2px solid #DDDDDD; transition: all 0.2s; }
.pay-option.active { border-color: #D85A30; background: #FAECE7; }
.pay-option-icon { font-size: 28px; display: block; margin-bottom: 6px; }
.pay-option-name { display: block; font-size: 15px; font-weight: 600; color: #2C2C2A; }
.pay-option-desc { display: block; font-size: 11px; color: #5F5E5A; margin-top: 2px; }
.pay-option.active .pay-option-name { color: #D85A30; }

.aa-preview { background: #fff; border-radius: 10px; padding: 12px 14px; margin-bottom: 10px; text-align: center; }
.aa-preview-text { font-size: 14px; color: #D85A30; font-weight: 500; }

/* Stars */
.star-row { display: flex; gap: 4px; }
.star { font-size: 32px; color: #DDDDDD; padding: 4px; }
.star.active { color: #D85A30; }

/* Navigation */
.step-nav { display: flex; gap: 10px; padding: 24px; }
.nav-btn { flex: 1; height: 48px; line-height: 48px; border-radius: 12px; font-size: 15px; font-weight: 500; text-align: center; }
.nav-btn.primary { background: #D85A30; color: #fff; }
.nav-btn.secondary { background: #fff; color: #2C2C2A; border: 1px solid #DDDDDD; }

/* 饭搭子弹窗 */
.modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.4); display: flex; align-items: center; justify-content: center; z-index: 100; }
.buddy-picker { background: #fff; border-radius: 20px; padding: 24px 20px; width: 300px; max-height: 70vh; display: flex; flex-direction: column; }
.buddy-picker-title { display: block; font-size: 17px; font-weight: 600; color: #2C2C2A; text-align: center; margin-bottom: 12px; }
.buddy-search { height: 40px; line-height: 40px; padding: 0 12px; background: #f5f5f5; border-radius: 10px; font-size: 14px; color: #2C2C2A; margin-bottom: 10px; }
.buddy-list { max-height: 300px; overflow-y: auto; }
.buddy-pick-item { display: flex; align-items: center; gap: 10px; padding: 10px 8px; border-bottom: 0.5px solid #f0f0f0; }
.bp-avatar { width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 14px; font-weight: 700; color: #fff; flex-shrink: 0; }
.bp-name { flex: 1; font-size: 14px; color: #2C2C2A; }
.bp-phone { font-size: 11px; color: #5F5E5A; }
.bp-add { font-size: 20px; color: #D85A30; font-weight: 700; }
.bp-empty { text-align: center; padding: 20px; font-size: 13px; color: #ccc; }
.buddy-close { height: 40px; line-height: 40px; background: #f5f5f5; color: #2C2C2A; font-size: 14px; border-radius: 10px; margin-top: 10px; }

/* Photo Grid */
.photo-grid { display: flex; flex-wrap: wrap; gap: 8px; }
.photo-preview { width: 80px; height: 80px; border-radius: 10px; overflow: hidden; position: relative; }
.photo-img { width: 100%; height: 100%; }
.photo-remove { position: absolute; top: 2px; right: 2px; width: 20px; height: 20px; line-height: 20px; text-align: center; background: rgba(0,0,0,0.5); color: #fff; border-radius: 50%; font-size: 14px; }
.photo-add { width: 80px; height: 80px; border-radius: 10px; border: 1.5px dashed #DDDDDD; display: flex; flex-direction: column; align-items: center; justify-content: center; background: #fff; }
.photo-add-icon { font-size: 28px; color: #ccc; line-height: 1; }
.photo-add-text { font-size: 11px; color: #ccc; margin-top: 2px; }
