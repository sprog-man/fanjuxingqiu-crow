<scroll-view class="page" scroll-y>
  <!-- 顶部：房间码 + 分享 -->
  <view class="room-header">
    <text class="room-code-label">房间号</text>
    <text class="room-code">{{roomCode}}</text>
    <button class="share-btn" bindtap="shareRoom">邀请好友</button>
  </view>

  <!-- 在线成员 -->
  <view class="members-section">
    <text class="section-title">在线成员（{{members.length}}人）</text>
    <view class="members-row">
      <view wx:for="{{members}}" wx:key="id" class="member-avatar">
        <view class="ma-circle" style="background:{{item.color}}">{{item.nickname.slice(0,1)}}</view>
        <text class="ma-name">{{item.nickname}}</text>
        <text wx:if="{{item.isHost}}" class="ma-host">房主</text>
      </view>
    </view>
  </view>

  <!-- 游戏选择（仅房主可见） -->
  <view wx:if="{{isHost && gameMode === ''}}" class="game-picker-host">
    <text class="section-title">选择游戏</text>
    <view class="gp-card" data-mode="draw" bindtap="startDraw">
      <text class="gp-icon">🎯</text>
      <view class="gp-text">
        <text class="gp-name">抽签</text>
        <text class="gp-desc">让运气决定谁买单</text>
      </view>
    </view>
    <view class="gp-card" data-mode="croc" bindtap="startGame">
      <text class="gp-icon">🐊</text>
      <view class="gp-text">
        <text class="gp-name">鳄鱼牙齿</text>
        <text class="gp-desc">轮流按牙齿，谁中招谁买单</text>
      </view>
    </view>
    <view class="gp-card" data-mode="pirate" bindtap="startGame">
      <text class="gp-icon">🏴‍☠️</text>
      <view class="gp-text">
        <text class="gp-name">海盗插刀</text>
        <text class="gp-desc">往木桶插刀，触发海盗的人买单</text>
      </view>
    </view>
  </view>

  <!-- 非房主等待提示 -->
  <view wx:if="{{!isHost && gameMode === ''}}" class="waiting-msg">
    <text class="waiting-text">等待房主开始游戏…</text>
  </view>

  <!-- ========== 抽签区域 ========== -->
  <view wx:if="{{gameMode === 'draw'}}" class="draw-section">

    <!-- 准备阶段：围成圆形 -->
    <view wx:if="{{drawPhase === 'idle'}}" class="draw-idle">
      <view class="draw-circle">
        <view wx:for="{{members}}" wx:key="id" class="draw-circle-item" style="transform:rotate({{index * 360 / members.length}}deg) translateY(-80px)">
          <view class="dci-avatar" style="background:{{item.color}}">{{item.nickname.slice(0,1)}}</view>
          <text class="dci-name">{{item.nickname}}</text>
        </view>
      </view>
      <button wx:if="{{isHost}}" class="draw-start-btn" bindtap="doDraw">🎯 开始抽签</button>
    </view>

    <!-- 倒计时 -->
    <view wx:if="{{drawPhase === 'countdown'}}" class="draw-countdown">
      <text class="countdown-num">{{countdown}}</text>
    </view>

    <!-- 轮转 -->
    <view wx:if="{{drawPhase === 'spinning'}}" class="draw-spin">
      <view wx:for="{{members}}" wx:key="id" class="spin-item {{spinHighlight === item.nickname ? 'highlight' : ''}}">
        <view class="si-avatar" style="background:{{item.color}}">{{item.nickname.slice(0,1)}}</view>
        <text class="si-name">{{item.nickname}}</text>
      </view>
    </view>

    <!-- 候选聚焦 -->
    <view wx:if="{{drawPhase === 'focus'}}" class="draw-focus">
      <view wx:for="{{shortlist}}" wx:for-item="name" wx:key="*this" class="focus-item">
        <view class="fo-avatar">{{name.slice(0,1)}}</view>
        <text class="fo-name">{{name}}</text>
      </view>
    </view>

    <!-- 揭晓 -->
    <view wx:if="{{drawPhase === 'reveal'}}" class="draw-reveal">
      <view class="reveal-winner">
        <view class="rw-avatar">{{drawWinner ? drawWinner.slice(0,1) : '?'}}</view>
        <text class="rw-name">{{drawWinner}}</text>
      </view>
      <text class="rw-label">🎉 恭喜请客！</text>
      <text class="rw-humor">{{humorLine}}</text>
      <button class="reset-btn" bindtap="resetDraw">再来一次</button>
    </view>
  </view>

  <!-- ========== 鳄鱼牙齿 / 海盗插刀 ========== -->
  <view wx:if="{{gameMode === 'croc' || gameMode === 'pirate'}}" class="game-section">
    <view class="turn-indicator">
      <text class="turn-label">当前轮到</text>
      <text class="turn-name">{{currentTurnName}}</text>
    </view>

    <view wx:if="{{gameMode === 'croc'}}" class="croc-wrap">
      <view class="croc-body {{gameResult ? 'bite' : ''}}">
        <view class="croc-head"></view>
        <view class="croc-jaw-upper">
          <view class="teeth-row">
            <view wx:for="{{gameBoard}}" wx:key="index" class="tooth {{item.state}} {{isMyTurn ? 'clickable' : ''}}" data-index="{{index}}" bindtap="pressTooth"></view>
          </view>
        </view>
        <view class="croc-jaw-lower"></view>
      </view>
    </view>

    <view wx:if="{{gameMode === 'pirate'}}" class="barrel-section">
      <view class="barrel {{gameResult ? 'shake' : ''}}">
        <view class="barrel-body">
          <view class="slot-grid">
            <view wx:for="{{gameBoard}}" wx:key="index" class="slot {{item.state}} {{isMyTurn ? 'clickable' : ''}}" data-index="{{index}}" bindtap="stabSlot">
              <view wx:if="{{item.state === 'stabbed'}}" class="knife"></view>
              <view wx:if="{{item.state === 'boom'}}" class="boom-effect">💥</view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{!isMyTurn && gamePhase === 'playing' && !gameResult}}" class="waiting-overlay">
      <text class="wo-text">等待 {{currentTurnName}} 操作…</text>
    </view>

    <view wx:if="{{gameResult}}" class="result-box">
      <text class="result-label">{{gameMode === 'croc' ? '💥 被咬了！' : '🏴‍☠️ 海盗出来了！'}}</text>
      <text class="result-name">{{gameResult}}</text>
      <text class="result-desc">你来买单！</text>
      <button class="reset-btn" bindtap="resetGame">再来一局</button>
    </view>
  </view>
</scroll-view>
