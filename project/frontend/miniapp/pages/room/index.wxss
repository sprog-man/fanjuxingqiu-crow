.page { min-height: 100vh; background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%); padding-bottom: 30px; color: #fff; }

/* === 顶部房间号 === */
.room-header { text-align: center; padding: 40px 24px 20px; }
.room-code-label { display: block; font-size: 12px; color: rgba(255,255,255,0.4); margin-bottom: 4px; }
.room-code { display: block; font-size: 32px; font-weight: 800; letter-spacing: 8px; color: #FFD700; font-family: monospace; margin-bottom: 12px; }
.share-btn { display: inline-block; height: 36px; line-height: 36px; padding: 0 24px; background: rgba(255,255,255,0.1); border-radius: 18px; font-size: 13px; color: rgba(255,255,255,0.8); border: none; }

/* === 成员 === */
.members-section { padding: 0 24px 16px; }
.section-title { display: block; font-size: 15px; font-weight: 600; margin-bottom: 12px; color: rgba(255,255,255,0.8); }
.members-row { display: flex; flex-wrap: wrap; gap: 12px; }
.member-avatar { display: flex; flex-direction: column; align-items: center; gap: 4px; width: 60px; }
.ma-circle { width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 16px; font-weight: 700; color: #fff; }
.ma-name { font-size: 11px; color: rgba(255,255,255,0.7); text-align: center; overflow: hidden; text-overflow: ellipsis; max-width: 60px; }
.ma-host { font-size: 9px; color: #FFD700; background: rgba(255,215,0,0.2); padding: 1px 6px; border-radius: 6px; }

/* === 游戏选择 === */
.game-picker-host { padding: 0 24px; }
.gp-card { display: flex; align-items: center; gap: 12px; background: rgba(255,255,255,0.06); border-radius: 16px; padding: 16px; margin-bottom: 10px; border: 0.5px solid rgba(255,255,255,0.08); }
.gp-card:active { transform: scale(0.97); }
.gp-icon { font-size: 28px; width: 44px; text-align: center; }
.gp-text { flex: 1; }
.gp-name { display: block; font-size: 16px; font-weight: 600; margin-bottom: 2px; }
.gp-desc { display: block; font-size: 11px; color: rgba(255,255,255,0.4); }

.waiting-msg { text-align: center; padding: 60px 24px; }
.waiting-text { font-size: 16px; color: rgba(255,255,255,0.5); }

/* === 抽签 — 三阶段 === */
.draw-section { padding: 20px 24px; }

/* 准备 */
.draw-idle { text-align: center; }
.draw-circle { position: relative; width: 200px; height: 200px; margin: 0 auto 24px; animation: breathe 3s ease-in-out infinite; }
.draw-circle-item { position: absolute; top: 50%; left: 50%; width: 44px; height: 44px; margin: -22px; display: flex; flex-direction: column; align-items: center; gap: 4px; }
.dci-avatar { width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 14px; font-weight: 700; color: #fff; }
.dci-name { font-size: 10px; color: rgba(255,255,255,0.7); white-space: nowrap; }

.draw-start-btn { height: 48px; line-height: 48px; padding: 0 40px; background: linear-gradient(135deg, #D85A30, #e8734a); border-radius: 24px; font-size: 17px; font-weight: 600; color: #fff; display: inline-block; box-shadow: 0 4px 20px rgba(216,90,48,0.4); border: none; }

/* 倒计时 */
.draw-countdown { display: flex; align-items: center; justify-content: center; height: 200px; }
.countdown-num { font-size: 80px; font-weight: 800; color: #FFD700; animation: countdown-pop 1s ease-out; }

/* 轮转 */
.draw-spin { display: flex; flex-wrap: wrap; justify-content: center; gap: 16px; min-height: 120px; padding: 20px 0; }
.spin-item { display: flex; flex-direction: column; align-items: center; gap: 6px; transition: all 0.3s; }
.spin-item.highlight .si-avatar { transform: scale(1.3); box-shadow: 0 0 16px rgba(255,215,0,0.6); }
.spin-item.highlight .si-name { color: #FFD700; font-weight: 700; }
.si-avatar { width: 44px; height: 44px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 16px; font-weight: 700; color: #fff; transition: all 0.3s; }
.si-name { font-size: 12px; color: rgba(255,255,255,0.6); }

/* 候选聚焦 */
.draw-focus { display: flex; justify-content: center; gap: 24px; padding: 30px 0; }
.focus-item { display: flex; flex-direction: column; align-items: center; gap: 8px; animation: candidate-glow 0.8s ease-in-out infinite alternate; }
.fo-avatar { width: 56px; height: 56px; border-radius: 50%; background: #D85A30; display: flex; align-items: center; justify-content: center; font-size: 22px; font-weight: 700; color: #fff; box-shadow: 0 0 16px rgba(216,90,48,0.4); }
.fo-name { font-size: 14px; font-weight: 600; color: #FFD700; }

/* 揭晓 */
.draw-reveal { text-align: center; padding: 20px 0; }
.reveal-winner { margin-bottom: 16px; }
.rw-avatar { width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 32px; font-weight: 700; color: #fff; margin: 0 auto 12px; background: #D85A30; animation: winner-spin 0.8s ease-out, golden-glow 1.5s ease-in-out infinite; }
.rw-name { display: block; font-size: 28px; font-weight: 700; color: #FFD700; margin-bottom: 8px; }
.rw-label { display: block; font-size: 18px; color: rgba(255,255,255,0.9); margin-bottom: 4px; }
.rw-humor { display: block; font-size: 14px; color: rgba(255,255,255,0.5); margin-bottom: 20px; }

/* === 小游戏 === */
.game-section { padding: 0 24px; }
.turn-indicator { text-align: center; padding: 12px 0 16px; }
.turn-label { font-size: 13px; color: rgba(255,255,255,0.5); }
.turn-name { font-size: 20px; font-weight: 700; color: #FFD700; }

.croc-wrap { background: rgba(255,255,255,0.06); border-radius: 20px; padding: 24px 14px; }
.croc-body.bite { animation: crocBite 0.6s ease-in-out; }
.croc-head { height: 36px; margin-bottom: 4px; }
.croc-jaw-upper { background: #3a3a3a; border-radius: 10px 10px 6px 6px; padding: 12px 6px 8px; }
.teeth-row { display: grid; grid-template-columns: repeat(7, 1fr); gap: 5px; }
.tooth { height: 34px; background: linear-gradient(180deg,#fff 60%,#f0f0f0); border-radius: 3px 3px 8px 8px; border: 1px solid #ddd; transition: all 0.2s; }
.tooth.clickable:active { transform: scale(0.85) !important; }
.tooth.safe { background: #d0d0d0; opacity: 0.5; transform: scale(0.75) translateY(4px); }
.tooth.danger { background: linear-gradient(180deg,#ff4444,#D85A30); animation: explode 0.6s ease-out; }
.croc-jaw-lower { width: 70%; height: 22px; background: linear-gradient(180deg,#238b65,#1D9E75); border-radius: 0 0 16px 16px; margin: -1px auto 0; }

.barrel-section { background: rgba(255,255,255,0.06); border-radius: 20px; padding: 24px 14px; }
.barrel.shake { animation: barrelShake 0.6s ease-in-out; }
.barrel-body { background: linear-gradient(180deg, #d4a050, #a06828); border-radius: 12px; padding: 16px; border: 3px solid #8a5a20; }
.slot-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }
.slot { aspect-ratio: 1; background: radial-gradient(circle at 35% 35%, #4a2a10, #2a1a08); border-radius: 50%; border: 2px solid #1a0e04; display: flex; align-items: center; justify-content: center; min-height: 32px; transition: all 0.25s; }
.slot.clickable:active { transform: scale(0.88); }
.slot.stabbed { background: radial-gradient(circle at 35% 35%, #6a4a20, #4a2a10); }
.slot.boom { background: radial-gradient(circle, #ff4444, #cc0000); animation: slotExplode 0.5s ease-out; }
.knife { width: 6px; height: 24px; background: #888; border-radius: 1px 1px 3px 3px; }
.boom-effect { font-size: 18px; }

.waiting-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 50; }
.wo-text { font-size: 16px; color: rgba(255,255,255,0.7); }

.result-box { text-align: center; padding: 24px 0; }
.result-label { display: block; font-size: 16px; color: #D85A30; margin-bottom: 4px; }
.result-name { display: block; font-size: 28px; font-weight: 700; color: #fff; margin-bottom: 4px; }
.result-desc { display: block; font-size: 14px; color: rgba(255,255,255,0.5); margin-bottom: 16px; }
.reset-btn { height: 40px; line-height: 40px; padding: 0 32px; background: rgba(255,255,255,0.1); color: #fff; font-size: 14px; border-radius: 10px; display: inline-block; border: none; }

/* === Keyframes === */
@keyframes breathe { 0%,100% { transform: scale(1); } 50% { transform: scale(1.03); } }
@keyframes countdown-pop { 0% { transform: scale(0.5); opacity: 0.3; } 50% { transform: scale(1.3); } 100% { transform: scale(1); opacity: 1; } }
@keyframes winner-spin { 0% { transform: rotateY(0deg) scale(0.5); opacity: 0; } 50% { transform: rotateY(180deg) scale(1.2); } 100% { transform: rotateY(360deg) scale(1); opacity: 1; } }
@keyframes golden-glow { 0%,100% { box-shadow: 0 0 10px #FFD700, 0 0 20px #FFD700; } 50% { box-shadow: 0 0 20px #FFD700, 0 0 40px #FFD700, 0 0 60px #FFA500; } }
@keyframes candidate-glow { from { transform: scale(1); } to { transform: scale(1.1); } }
@keyframes crocBite { 0% { transform: translateY(0); } 30% { transform: translateY(10px); } 60% { transform: translateY(-3px); } 100% { transform: translateY(0); } }
@keyframes explode { 0% { transform: scale(1); } 20% { transform: scale(1.4); background: #ff2222; } 100% { transform: scale(1); } }
@keyframes barrelShake { 0%,100% { transform: translateY(0); } 20% { transform: translateY(-8px) rotate(-3deg); } 40% { transform: translateY(4px) rotate(3deg); } 60% { transform: translateY(-4px) rotate(-2deg); } 80% { transform: translateY(2px) rotate(1deg); } }
@keyframes slotExplode { 0% { transform: scale(1); } 50% { transform: scale(1.4); box-shadow: 0 0 20px rgba(255,0,0,0.6); } 100% { transform: scale(1); } }
