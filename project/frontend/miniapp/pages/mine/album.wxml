<scroll-view class="page" scroll-y>
  <view class="header">
    <text class="header-title">聚餐相册</text>
    <text class="header-sub">每一次聚餐都值得被记住</text>
  </view>

  <!-- Album Grid -->
  <view class="album-grid">
    <view wx:for="{{albums}}" wx:key="gathering_id" class="album-card" data-index="{{index}}" bindtap="openAlbum">
      <view class="album-cover" style="background:{{coverColors[index % coverColors.length]}}">
        <text class="album-cover-text">{{item.title.slice(0,2)}}</text>
        <view class="album-cost">{{item.totalCost}}元</view>
      </view>
      <view class="album-body">
        <text class="album-title">{{item.title}}</text>
        <text class="album-date">{{formatDate(item.dateTime)}}</text>
        <view class="album-meta">
          <view class="album-avatars">
            <text wx:for="{{item.participants.slice(0,5)}}" wx:key="*this" class="album-avatar">{{item.slice(0,1)}}</text>
            <text wx:if="{{item.participants.length > 5}}" class="album-avatar-more">+{{item.participants.length - 5}}</text>
          </view>
          <view class="album-tags">
            <text wx:for="{{item.moodTags}}" wx:key="*this" class="album-tag">{{item}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- Album Detail Modal -->
  <view wx:if="{{selectedAlbum}}" class="modal-overlay" bindtap="closeAlbum">
    <scroll-view class="modal-scroll" scroll-y catchtap>
      <view class="modal-hero" style="background:{{coverColors[selectedIndex % coverColors.length]}}">
        <text class="modal-hero-title">{{selectedAlbum.title}}</text>
        <text class="modal-hero-meta">{{albumDate}} · {{albumLocation}}</text>
      </view>

      <view class="modal-section">
        <view class="modal-info-row">
          <view class="modal-info-item"><text class="mi-label">总消费</text><text class="mi-value accent">{{selectedAlbum.totalCost}}元</text></view>
          <view class="modal-info-item"><text class="mi-label">人均</text><text class="mi-value">{{albumAvgCost}}元</text></view>
          <view class="modal-info-item"><text class="mi-label">满意度</text><text class="mi-value">{{albumStars || '-'}}</text></view>
        </view>
      </view>

      <view wx:if="{{selectedAlbum.photos && selectedAlbum.photos.length}}" class="modal-section">
        <text class="modal-section-title">照片</text>
        <scroll-view class="photo-scroll" scroll-x>
          <image wx:for="{{selectedAlbum.photos}}" wx:key="*this" class="photo-thumb" src="{{item}}" mode="aspectFill" data-url="{{item}}" bindtap="previewPhoto" />
        </scroll-view>
      </view>

      <view class="modal-section">
        <text class="modal-section-title">回忆文字</text>
        <view class="memory-card">
          <text class="memory-text">{{aiMemory || '生成中...'}}</text>
        </view>
        <view class="memory-actions">
          <button class="memory-btn" bindtap="generateMemory">重新生成</button>
        </view>
      </view>

      <view class="modal-section">
        <text class="modal-section-title">参与人员</text>
        <view class="modal-participants">
          <text wx:for="{{selectedAlbum.participants}}" wx:key="*this" class="mp-badge">{{item}}</text>
        </view>
      </view>

      <view wx:if="{{selectedAlbum.moodTags && selectedAlbum.moodTags.length}}" class="modal-section">
        <text class="modal-section-title">心情标签</text>
        <view class="modal-tags">
          <text wx:for="{{selectedAlbum.moodTags}}" wx:key="*this" class="mt-badge">{{item}}</text>
        </view>
      </view>

      <view wx:if="{{selectedAlbum.note}}" class="modal-section">
        <text class="modal-section-title">备注</text>
        <text class="modal-note">{{selectedAlbum.note}}</text>
      </view>

      <view class="modal-section">
        <button class="poster-btn" bindtap="generatePoster">生成分享海报</button>
      </view>

      <view class="modal-close-area" bindtap="closeAlbum">
        <button class="modal-close-btn">关闭</button>
      </view>
    </scroll-view>
  </view>

  <!-- Hidden Poster Canvas -->
  <canvas type="2d" id="posterCanvas" style="width:540px;height:810px;position:fixed;left:-9999px;top:0;pointer-events:none"></canvas>

  <!-- Empty State -->
  <view wx:if="{{albums.length === 0}}" class="empty-state">
    <text class="empty-icon">📸</text>
    <text class="empty-text">还没有聚餐相册</text>
    <text class="empty-hint">去记录本创建一条聚餐记录吧</text>
  </view>
</scroll-view>
