<scroll-view class="page" scroll-y>
  <view class="header">
    <text class="header-title">关系图鉴</text>
    <text class="header-sub">你和好友的聚餐羁绊网络</text>
  </view>

  <!-- Graph Canvas with touch -->
  <view class="graph-container">
    <canvas type="2d" id="graphCanvas"
      class="graph-canvas"
      style="width:{{canvasW}}px;height:{{canvasH}}px"
      bindtouchstart="onTouchStart"
      bindtouchmove="onTouchMove"
      bindtouchend="onTouchEnd"
    ></canvas>
  </view>

  <!-- Friend List -->
  <view class="friend-list">
    <view wx:for="{{friends}}" wx:key="name" class="friend-card" data-name="{{item.name}}" bindtap="showDetail">
      <view class="friend-avatar" style="background:{{item.color}}">
        <text class="friend-avatar-text">{{item.initial}}</text>
      </view>
      <view class="friend-info">
        <view class="friend-top">
          <text class="friend-name">{{item.name}}</text>
          <text class="friend-title">{{item.title}}</text>
        </view>
        <text class="friend-level">{{item.level}}</text>
        <text class="friend-desc">{{item.desc}}</text>
        <view class="friend-stats">
          <text>{{item.gatherCount}}次聚餐</text>
          <text>{{item.cities.length}}座城市</text>
        </view>
      </view>
      <text class="friend-arrow">›</text>
    </view>
  </view>

  <!-- Detail Modal -->
  <view wx:if="{{detailFriend}}" class="modal-overlay" bindtap="closeDetail">
    <view class="modal-card {{detailFriend ? 'show' : ''}}" catchtap="preventClose">
      <view class="modal-glow" style="background:{{detailFriend.color}}"></view>
      <view class="modal-avatar" style="background:{{detailFriend.color}}">
        <text>{{detailFriend.initial}}</text>
      </view>
      <text class="modal-name">{{detailFriend.name}}</text>
      <view class="modal-title-badge">
        <text>{{detailFriend.title}}</text>
        <text>{{detailFriend.level}}</text>
      </view>
      <text class="modal-desc">{{detailFriend.desc}}</text>
      <view class="modal-stats">
        <view class="modal-stat"><text class="ms-num">{{detailFriend.gatherCount}}</text><text class="ms-label">共餐次数</text></view>
        <view class="modal-stat"><text class="ms-num">{{detailFriend.totalSpent}}</text><text class="ms-label">累计消费</text></view>
        <view class="modal-stat"><text class="ms-num">{{detailFriend.cities.length}}</text><text class="ms-label">共同城市</text></view>
      </view>
      <view wx:if="{{detailFriend.cities && detailFriend.cities.length}}" class="modal-cities">
        <text wx:for="{{detailFriend.cities}}" wx:key="*this" class="city-badge">{{item}}</text>
      </view>
      <button class="modal-close" bindtap="closeDetail">关闭</button>
    </view>
  </view>
</scroll-view>
