<view class="page">
  <view class="profile-header">
    <view class="avatar" bindtap="doLogin">
      <image wx:if="{{userInfo && userInfo.avatar_url}}" class="avatar-img" src="{{userInfo.avatar_url}}" mode="aspectFill"></image>
      <text wx:else class="avatar-placeholder">{{userInfo ? userInfo.nickname.slice(0,1) : '👤'}}</text>
    </view>
    <text class="nickname" bindtap="doLogin">{{userInfo ? userInfo.nickname : '点击登录'}}</text>
    <text class="bio">{{userInfo ? '已登录' : '登录后享受完整功能'}}</text>
  </view>
  <view class="menu-list">
    <view class="menu-item" bindtap="goRelation">
      <text class="menu-icon">🔗</text>
      <text class="menu-name">关系图鉴</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goAlbum">
      <text class="menu-icon">📸</text>
      <text class="menu-name">聚餐相册</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goBuddies">
      <text class="menu-icon">👥</text>
      <text class="menu-name">饭搭子</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="doLogout" wx:if="{{userInfo}}">
      <text class="menu-icon">🚪</text>
      <text class="menu-name" style="color:#e55">退出登录</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
