/**app.wxss - 饭局星球 全局样式**/

page {
  --primary: #D85A30;
  --primary-light: #FAECE7;
  --success: #1D9E75;
  --purple: #534AB7;
  --blue: #185FA5;
  --amber: #BA7517;
  --text-primary: #2C2C2A;
  --text-secondary: #5F5E5A;
  --border: #DDDDDD;
  --bg: #f8f6f3;

  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", "PingFang SC", sans-serif;
  color: var(--text-primary);
  background: var(--bg);
  font-size: 15px;
  line-height: 1.4;
  -webkit-font-smoothing: antialiased;
}

view, text, scroll-view {
  box-sizing: border-box;
}

button {
  border: none;
  outline: none;
  padding: 0;
  margin: 0;
  background: none;
}

button::after {
  border: none;
}
