<mxCell id="u-title" value="&lt;b&gt;饭局星球 — 数据库 ER 图&lt;/b&gt;&lt;hr&gt;MongoDB 8 集合 · 标注主键(PK)与外键(FK)关系" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2C3E50;fontColor=#FFFFFF;fontSize=14;align=center;arcSize=10;" vertex="1" parent="1"><mxGeometry x="260" y="10" width="380" height="50" as="geometry" /></mxCell><mxCell id="u-user" value="&lt;b&gt;User 用户&lt;/b&gt;&lt;hr&gt;openid (PK)&lt;br&gt;nickname&lt;br&gt;avatar_url&lt;br&gt;phone&lt;br&gt;preference_tags&lt;br&gt;friend_ids[]&lt;br&gt;buddy_id (unique)&lt;br&gt;created_at / updated_at" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D85A30;fontColor=#FFFFFF;align=left;arcSize=14;" vertex="1" parent="1"><mxGeometry x="300" y="250" width="190" height="170" as="geometry" /></mxCell><mxCell id="u-gather" value="&lt;b&gt;Gathering 聚餐记录&lt;/b&gt;&lt;hr&gt;_id (PK)&lt;br&gt;title&lt;br&gt;dateTime&lt;br&gt;location {name,lat,lng,city}&lt;br&gt;participants[]&lt;br&gt;payer&lt;br&gt;totalCost&lt;br&gt;photos[]&lt;br&gt;moodScore (1-5)&lt;br&gt;moodTags[] / foodTags[]&lt;br&gt;note / cover / isCheckin&lt;br&gt;&lt;b&gt;creatorId (FK → User)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1D9E75;fontColor=#FFFFFF;align=left;arcSize=14;" vertex="1" parent="1"><mxGeometry x="580" y="220" width="210" height="200" as="geometry" /></mxCell><mxCell id="u-relation" value="&lt;b&gt;Relation 关系图鉴&lt;/b&gt;&lt;hr&gt;_id (PK)&lt;br&gt;&lt;b&gt;userA (FK → User)&lt;/b&gt;&lt;br&gt;&lt;b&gt;userB (FK → User)&lt;/b&gt;&lt;br&gt;gatherCount&lt;br&gt;title (称号)&lt;br&gt;cities[] / totalSpent&lt;br&gt;lastGatherAt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#534AB7;fontColor=#FFFFFF;align=left;arcSize=14;" vertex="1" parent="1"><mxGeometry x="300" y="480" width="190" height="160" as="geometry" /></mxCell><mxCell id="u-buddy" value="&lt;b&gt;Buddy 饭搭子申请&lt;/b&gt;&lt;hr&gt;_id (PK)&lt;br&gt;&lt;b&gt;openid (FK → User)&lt;/b&gt;&lt;br&gt;&lt;b&gt;targetUserId (FK → User._id)&lt;/b&gt;&lt;br&gt;remark / requestMessage&lt;br&gt;status: pending│accepted│rejected" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#185FA5;fontColor=#FFFFFF;align=left;arcSize=14;" vertex="1" parent="1"><mxGeometry x="580" y="500" width="210" height="140" as="geometry" /></mxCell><mxCell id="u-aa" value="&lt;b&gt;AARecord AA记账&lt;/b&gt;&lt;hr&gt;_id (PK)&lt;br&gt;&lt;b&gt;groupId (FK → Gathering)&lt;/b&gt;&lt;br&gt;payer / participants[]&lt;br&gt;amount / paidStatus (Map)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BA7517;fontColor=#FFFFFF;align=left;arcSize=14;" vertex="1" parent="1"><mxGeometry x="860" y="260" width="190" height="130" as="geometry" /></mxCell><mxCell id="u-invite" value="&lt;b&gt;Invitation 房间邀请&lt;/b&gt;&lt;hr&gt;_id (PK)&lt;br&gt;&lt;b&gt;fromOpenid (FK → User)&lt;/b&gt;&lt;br&gt;fromNickname&lt;br&gt;&lt;b&gt;toOpenid (FK → User)&lt;/b&gt;&lt;br&gt;roomCode&lt;br&gt;status: pending│accepted│rejected│expired" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2C3E50;fontColor=#FFFFFF;align=left;arcSize=14;" vertex="1" parent="1"><mxGeometry x="40" y="470" width="210" height="150" as="geometry" /></mxCell><mxCell id="u-cuisine" value="&lt;b&gt;Cuisine 菜系&lt;/b&gt;&lt;hr&gt;id (PK)&lt;br&gt;name / icon / color&lt;br&gt;tags[]&lt;br&gt;enabled / tarotCover" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D85A30;fontColor=#FFFFFF;align=left;arcSize=14;" vertex="1" parent="1"><mxGeometry x="50" y="240" width="170" height="120" as="geometry" /></mxCell><mxCell id="u-dish" value="&lt;b&gt;Dish 菜品&lt;/b&gt;&lt;hr&gt;_id (PK)&lt;br&gt;name&lt;br&gt;&lt;b&gt;cuisineId (FK → Cuisine)&lt;/b&gt;&lt;br&gt;openid (FK → User)&lt;br&gt;image / tags[] / description&lt;br&gt;popularity / enabled" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1D9E75;fontColor=#FFFFFF;align=left;arcSize=14;" vertex="1" parent="1"><mxGeometry x="50" y="420" width="190" height="150" as="geometry" /></mxCell><mxCell id="ue1" value="1" style="endArrow=ERmany;html=1;rounded=0;strokeWidth=2;fontSize=14;exitX=1;exitY=0.2;entryX=0;entryY=0.2;" edge="1" parent="1" source="u-user" target="u-gather"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="ue1l" value="创建聚餐" style="edgeLabel;html=1;align=center;fontSize=11;fontColor=#1D9E75;" vertex="1" connectable="0" parent="ue1"><mxGeometry x="-0.15" y="1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell><mxCell id="ue2" value="1" style="endArrow=ERmany;html=1;rounded=0;strokeWidth=2;fontSize=14;exitX=1;exitY=0.55;entryX=0;entryY=0.3;" edge="1" parent="1" source="u-user" target="u-relation"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="ue2l" value="作为 userA / userB" style="edgeLabel;html=1;align=center;fontSize=11;fontColor=#534AB7;" vertex="1" connectable="0" parent="ue2"><mxGeometry x="-0.15" y="-1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell><mxCell id="ue3" value="1" style="endArrow=ERmany;html=1;rounded=0;strokeWidth=2;fontSize=14;exitX=1;exitY=0.3;entryX=0;entryY=0.3;" edge="1" parent="1" source="u-gather" target="u-aa"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="ue3l" value="AA 分摊" style="edgeLabel;html=1;align=center;fontSize=11;fontColor=#BA7517;" vertex="1" connectable="0" parent="ue3"><mxGeometry x="-0.2" y="1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell><mxCell id="ue4" value="1" style="endArrow=ERmany;html=1;rounded=0;strokeWidth=2;fontSize=14;exitX=1;exitY=0.5;entryX=0;entryY=0.4;" edge="1" parent="1" source="u-cuisine" target="u-dish"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="ue4l" value="包含" style="edgeLabel;html=1;align=center;fontSize=11;fontColor=#1D9E75;" vertex="1" connectable="0" parent="ue4"><mxGeometry x="-0.25" y="1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell><mxCell id="ue5" value="" style="endArrow=ERone;html=1;rounded=0;strokeWidth=2;fontSize=14;exitX=1;exitY=0.6;entryX=0;entryY=0.2;dashed=1;startArrow=ERmany;startFill=0;" edge="1" parent="1" source="u-user" target="u-buddy"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="ue5l" value="发起申请" style="edgeLabel;html=1;align=center;fontSize=11;fontColor=#185FA5;" vertex="1" connectable="0" parent="ue5"><mxGeometry x="-0.35" y="-1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell><mxCell id="ue6" value="" style="endArrow=ERmany;html=1;rounded=0;strokeWidth=2;fontSize=14;exitX=0;exitY=0.4;entryX=0.35;entryY=0;dashed=1;startArrow=ERone;startFill=0;" edge="1" parent="1" source="u-invite" target="u-user"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="ue6l" value="邀请 / 被邀请" style="edgeLabel;html=1;align=center;fontSize=11;fontColor=#2C3E50;" vertex="1" connectable="0" parent="ue6"><mxGeometry x="-0.4" y="-1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell><mxCell id="ue7" value="" style="endArrow=ERmany;html=1;rounded=0;strokeWidth=2;fontSize=14;exitX=0.25;exitY=1;entryX=0;entryY=0.4;dashed=1;startArrow=ERone;startFill=0;" edge="1" parent="1" source="u-dish" target="u-user"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="ue7l" value="自创菜品" style="edgeLabel;html=1;align=center;fontSize=11;fontColor=#1D9E75;" vertex="1" connectable="0" parent="ue7"><mxGeometry x="0.2" y="-2" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell></root></mxGraphModel></diagram><diagram id="33j8ck2m-a3g3" name="程序流图 (Program Flow)"><mxGraphModel><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="p1" value="&lt;b&gt;饭局星球 — 程序流图&lt;/b&gt;&lt;hr&gt;一个 HTTP 请求从客户端到数据库的完整生命周期" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2C3E50;fontColor=#FFFFFF;fontSize=14;align=center;arcSize=10;" vertex="1" parent="1"><mxGeometry x="200" y="10" width="400" height="50" as="geometry" /></mxCell><mxCell id="p2" value="&lt;b&gt;📱 微信小程序客户端&lt;/b&gt;&lt;hr&gt;pages/eat (转盘)&lt;br&gt;pages/pay (游戏)&lt;br&gt;pages/record (记录)&lt;br&gt;pages/map (地图)&lt;br&gt;pages/mine (我的)&lt;br&gt;subpackages (子包)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D85A30;fontColor=#FFFFFF;align=left;arcSize=10;" vertex="1" parent="1"><mxGeometry x="40" y="120" width="180" height="150" as="geometry" /></mxCell><mxCell id="p3" value="&lt;b&gt;安全中间件层&lt;/b&gt;&lt;hr&gt;helmet (安全头)&lt;br&gt;cors (跨域)&lt;br&gt;rateLimit (限流)&lt;br&gt;express.json(1mb)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#185FA5;fontColor=#FFFFFF;align=left;arcSize=10;" vertex="1" parent="1"><mxGeometry x="40" y="340" width="180" height="130" as="geometry" /></mxCell><mxCell id="p4" value="&lt;b&gt;Express 路由层&lt;/b&gt;&lt;hr&gt;/api/auth - 登录认证&lt;br&gt;/api/wheel - 转盘&lt;br&gt;/api/game - 游戏&lt;br&gt;/api/gathering - 记录 CRUD&lt;br&gt;/api/relation - 关系图鉴&lt;br&gt;/api/map - 打卡地图&lt;br&gt;/api/buddy - 好友管理&lt;br&gt;/api/ai - AI 回忆文字&lt;br&gt;/api/tarot - 塔罗牌&lt;br&gt;/api/preference - 偏好&lt;br&gt;/api/room - 房间&lt;br&gt;/api/admin - 管理后台&lt;br&gt;/api/seed - 种子数据" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1D9E75;fontColor=#FFFFFF;align=left;arcSize=10;" vertex="1" parent="1"><mxGeometry x="320" y="120" width="220" height="260" as="geometry" /></mxCell><mxCell id="p5" value="&lt;b&gt;MongoDB 数据库&lt;/b&gt;&lt;hr&gt;users&lt;br&gt;gatherings&lt;br&gt;relations&lt;br&gt;buddies&lt;br&gt;aaRecords&lt;br&gt;invitations&lt;br&gt;cuisines&lt;br&gt;dishes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#534AB7;fontColor=#FFFFFF;align=left;arcSize=10;" vertex="1" parent="1"><mxGeometry x="320" y="440" width="220" height="190" as="geometry" /></mxCell><mxCell id="p6" value="&lt;b&gt;WebSocket 服务&lt;/b&gt;&lt;hr&gt;房间管理 (6位码)&lt;br&gt;实时游戏同步&lt;br&gt;心跳保活 (30s)&lt;br&gt;断线重连&lt;br&gt;邀请推送" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BA7517;fontColor=#FFFFFF;align=left;arcSize=10;" vertex="1" parent="1"><mxGeometry x="600" y="120" width="180" height="150" as="geometry" /></mxCell><mxCell id="p7" value="&lt;b&gt;阿里云 OSS&lt;/b&gt;&lt;hr&gt;头像存储&lt;br&gt;塔罗图片&lt;br&gt;聚餐相册" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BA7517;fontColor=#FFFFFF;align=left;arcSize=10;" vertex="1" parent="1"><mxGeometry x="600" y="340" width="180" height="110" as="geometry" /></mxCell><mxCell id="p8" value="&lt;b&gt;管理后台&lt;/b&gt;&lt;hr&gt;纯 HTML/CSS/JS&lt;br&gt;JWT 认证&lt;br&gt;数据概览&lt;br&gt;用户管理&lt;br&gt;记录管理" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2C3E50;fontColor=#FFFFFF;align=left;arcSize=10;" vertex="1" parent="1"><mxGeometry x="600" y="510" width="180" height="140" as="geometry" /></mxCell><mxCell id="p9" value="&lt;b&gt;wx.setStorageSync&lt;/b&gt;&lt;hr&gt;离线缓存层&lt;br&gt;(双写模式)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BA7517;fontColor=#FFFFFF;align=left;arcSize=10;" vertex="1" parent="1"><mxGeometry x="40" y="530" width="180" height="80" as="geometry" /></mxCell><mxCell id="pe1" value="HTTP/HTTPS 请求" style="endArrow=block;html=1;rounded=0;strokeWidth=2;fontSize=11;" edge="1" parent="1" source="p2" target="p3"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="pe2" value="中间件处理后转发" style="endArrow=block;html=1;rounded=0;strokeWidth=2;fontSize=11;" edge="1" parent="1" source="p3" target="p4"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="pe3" value="Mongoose CRUD" style="endArrow=block;html=1;rounded=0;strokeWidth=2;fontSize=11;" edge="1" parent="1" source="p4" target="p5"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="pe4" value="WebSocket upgrade" style="endArrow=block;html=1;rounded=0;strokeWidth=2;fontSize=11;dashed=1;" edge="1" parent="1" source="p3" target="p6"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="pe5" value="文件上传" style="endArrow=block;html=1;rounded=0;strokeWidth=2;fontSize=11;dashed=1;" edge="1" parent="1" source="p4" target="p7"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="pe6" value="静态文件服务" style="endArrow=block;html=1;rounded=0;strokeWidth=2;fontSize=11;dashed=1;" edge="1" parent="1" source="p4" target="p8"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="pe7" value="离线兜底 / 双写" style="endArrow=block;html=1;rounded=0;strokeWidth=2;fontSize=11;dashed=1;" edge="1" parent="1" source="p2" target="p9"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="pe8" value="游戏事件" style="endArrow=block;html=1;rounded=0;strokeWidth=2;fontSize=11;" edge="1" parent="1" source="p6" target="p4"><mxGeometry relative="1" as="geometry" /></mxCell></root></mxGraphModel></diagram><diagram id="p7pplws5-ys55" name="控制流图 (Control Flow)"><mxGraphModel><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="c-title" value="&lt;b&gt;饭局星球 — 控制流图&lt;/b&gt;&lt;hr&gt;核心业务流程的状态转换" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2C3E50;fontColor=#FFFFFF;fontSize=14;align=center;arcSize=10;" vertex="1" parent="1"><mxGeometry x="200" y="10" width="400" height="50" as="geometry" /></mxCell><mxCell id="c-section1" value="&lt;b&gt;① 微信登录流程&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=14;fontColor=#D85A30;" vertex="1" parent="1"><mxGeometry x="40" y="90" width="200" height="30" as="geometry" /></mxCell><mxCell id="c-auth1" value="小程序启动" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAECE7;fontColor=#D85A30;align=center;arcSize=10;" vertex="1" parent="1"><mxGeometry x="40" y="130" width="120" height="40" as="geometry" /></mxCell><mxCell id="c-auth2" value="wx.login()\n获取 code" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAECE7;fontColor=#D85A30;align=center;arcSize=10;" vertex="1" parent="1"><mxGeometry x="40" y="200" width="120" height="40" as="geometry" /></mxCell><mxCell id="c-auth3" value="有 AppID？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#185FA5;fontColor=#FFFFFF;align=center;arcSize=10;" vertex="1" parent="1"><mxGeometry x="210" y="195" width="100" height="50" as="geometry" /></mxCell><mxCell id="c-auth4" value="jscode2session\n+ JWT 签发" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1D9E75;fontColor=#FFFFFF;align=center;arcSize=10;" vertex="1" parent="1"><mxGeometry x="380" y="130" width="130" height="40" as="geometry" /></mxCell><mxCell id="c-auth5" value="Mock 降级\ndev_xxx 模式" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BA7517;fontColor=#FFFFFF;align=center;arcSize=10;" vertex="1" parent="1"><mxGeometry x="380" y="210" width="130" height="40" as="geometry" /></mxCell><mxCell id="c-auth6" value="返回 token + user\n存入 storage" style="rounded=4;whiteSpace=wrap;html=1;fillColor=#534AB7;fontColor=#FFFFFF;align=center;arcSize=10;" vertex="1" parent="1"><mxGeometry x="210" y="300" width="100" height="40" as="geometry" /></mxCell><mxCell id="c-a1" value="" style="endArrow=block;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="c-auth1" target="c-auth2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="c-a2" value="" style="endArrow=block;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="c-auth2" target="c-auth3"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="c-a3" value="是" style="endArrow=block;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="c-auth3" target="c-auth4"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="c-a4" value="否" style="endArrow=block;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="c-auth3" target="c-auth5"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="c-a5" value="" style="endArrow=block;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="c-auth4" target="c-auth6"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="c-a6" value="" style="endArrow=block;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="c-auth5" target="c-auth6"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="c-section2" value="&lt;b&gt;② WebSocket 房间游戏流程&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=14;fontColor=#534AB7;" vertex="1" parent="1"><mxGeometry x="560" y="90" width="240" height="30" as="geometry" /></mxCell><mxCell id="c-ws1" value="创建房间\n(6位随机码)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAECE7;fontColor=#534AB7;align=center;arcSize=10;" vertex="1" parent="1"><mxGeometry x="560" y="130" width="130" height="40" as="geometry" /></mxCell><mxCell id="c-ws2" value="加入房间\n(输入房间码)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAECE7;fontColor=#534AB7;align=center;arcSize=10;" vertex="1" parent="1"><mxGeometry x="740" y="130" width="130" height="40" as="geometry" /></mxCell><mxCell id="c-ws3" value="选择游戏\n抽签/鳄鱼/海盗" style="rhombus;whiteSpace=wrap;html=1;fillColor=#534AB7;fontColor=#FFFFFF;align=center;arcSize=10;" vertex="1" parent="1"><mxGeometry x="640" y="200" width="120" height="50" as="geometry" /></mxCell><mxCell id="c-ws4" value="游戏进行中\n轮流操作" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1D9E75;fontColor=#FFFFFF;align=center;arcSize=10;" vertex="1" parent="1"><mxGeometry x="580" y="290" width="100" height="40" as="geometry" /></mxCell><mxCell id="c-ws5" value="是否触发\n危险/爆炸？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#D85A30;fontColor=#FFFFFF;align=center;arcSize=10;" vertex="1" parent="1"><mxGeometry x="740" y="285" width="120" height="50" as="geometry" /></mxCell><mxCell id="c-ws6" value="游戏结束\n公布输家" style="rounded=4;whiteSpace=wrap;html=1;fillColor=#D85A30;fontColor=#FFFFFF;align=center;arcSize=10;" vertex="1" parent="1"><mxGeometry x="640" y="380" width="120" height="40" as="geometry" /></mxCell><mxCell id="c-ws7" value="断开连接\n标记离线 (不踢出)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BA7517;fontColor=#FFFFFF;align=center;arcSize=10;" vertex="1" parent="1"><mxGeometry x="640" y="460" width="120" height="50" as="geometry" /></mxCell><mxCell id="c-ws8" value="房间过期\n(10min 无活动)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BA7517;fontColor=#FFFFFF;align=center;arcSize=10;" vertex="1" parent="1"><mxGeometry x="640" y="550" width="130" height="40" as="geometry" /></mxCell><mxCell id="c-b1" value="" style="endArrow=block;html=1;rounded=0